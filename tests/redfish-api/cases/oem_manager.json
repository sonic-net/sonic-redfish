  {
    "name": "test_submit_alert_missing_top_level_key_returns_400",
    "description": "SubmitAlert without a 'redfish.*' key returns PropertyMissing",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert",
    "body": { "NotRedfishAlertData": {} },
    "expected_status": 400,
    "expected_response": {
      "redfish@Message.ExtendedInfo": [
        {
          "MessageId": "Base.1.19.PropertyMissing",
          "MessageArgs": ["redfish"]
        }
      ]
    }
  },
  {
    "name": "test_submit_telemetry_missing_top_level_key_returns_400",
    "description": "SubmitTelemetry without 'Alarms' returns PropertyMissing",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitTelemetry",
    "body": { "NotPresent": {} },
    "expected_status": 400,
    "expected_response": {
      "Alarms@Message.ExtendedInfo": [
        {
          "MessageId": "Base.1.19.PropertyMissing",
          "MessageArgs": ["Alarms"]
        }
      ]
