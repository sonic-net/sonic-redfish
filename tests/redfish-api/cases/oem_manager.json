  {
    "name": "test_submit_telemetry_persists_to_state_db",
    "description": "SubmitTelemetry fans measurements and leak out to per-sensor RACK_MANAGER_DATA keys",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitTelemetry",
    "redis_setup": [
      {
        "db": "state_db",
        "action": "delete",
        "keys": [
          "RACK_MANAGER_DATA|Inlet_liquid_temperature",
          "RACK_MANAGER_DATA|Inlet_liquid_flow_rate",
          "RACK_MANAGER_DATA|Inlet_liquid_pressure",
          "RACK_MANAGER_DATA|Rack_level_leak"
        ]
      }
    ],
    "body": {
      "Alarms": {
        "InletTempDeviation":      { "InletTemperature": 25.3, "Severity": "Major" },
        "FlowRateDeviation":       { "FlowRate": 28,           "Severity": "Normal" },
        "LiquidPressureDeviation": { "LiquidPressure": 2,      "Severity": "Critical" },
        "LeakDetected":            { "Severity": "Critical" }
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RACK_MANAGER_DATA|Rack_level_leak",
        "wait_for_field": "leak",
        "timeout": 5.0,
        "expected_fields": {
          "leak":      "Critical",
          "timestamp": { "exists": true },
          "value":     { "exists": false },
          "unit":      { "exists": false },
          "severity":  { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_DATA|Inlet_liquid_temperature",
        "expected_fields": {
          "InletTemperature": { "type": "float", "equals": 25.3 },
          "unit":             "C",
          "severity":         "Major",
          "timestamp":        { "exists": true },
          "rscm_position":    { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_DATA|Inlet_liquid_flow_rate",
        "expected_fields": {
          "value":     { "type": "float", "equals": 28 },
          "unit":      "gallons_per_min",
          "severity":  "Normal",
          "timestamp": { "exists": true }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_DATA|Inlet_liquid_pressure",
        "expected_fields": {
          "value":     { "type": "float", "equals": 2 },
          "unit":      "psi",
          "severity":  "Critical",
          "timestamp": { "exists": true }
        }
      }
    ]
  },
  {
    "name": "test_submit_alert_flat_form_persists",
    "description": "Flat-form SubmitAlert fans measurements and leak out to per-sensor RACK_MANAGER_ALERT keys (severity/timestamp only)",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert",
    "redis_setup": [
      {
        "db": "state_db",
        "action": "delete",
        "keys": [
          "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
          "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
          "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
          "RACK_MANAGER_ALERT|Rack_level_leak"
        ]
      }
    ],
    "body": {
      "redfish_alert_data": {
        "Alerts": {
          "InletTemperature": 18,
          "FlowRate": 58,
          "Severity": "Minor"
        },
        "LiquidPressureDeviation": {
          "LiquidPressure": 68,
          "Severity": "Major"
        },
        "LeakDetected": { "Severity": "Critical" }
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Rack_level_leak",
        "wait_for_field": "leak",
        "expected_fields": {
          "leak":      "Critical",
          "timestamp": { "exists": true }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
        "expected_fields": {
          "severity":      "Minor",
          "timestamp":     { "exists": true },
          "value":         { "exists": false },
          "unit":          { "exists": false },
          "rscm_position": { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
        "expected_fields": {
          "severity":  "Minor",
          "timestamp": { "exists": true },
          "value":     { "exists": false },
          "unit":      { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
        "expected_fields": {
          "severity":  "Major",
          "timestamp": { "exists": true },
          "value":     { "exists": false },
          "unit":      { "exists": false }
        }
      }
    ]
  },
  {
    "name": "test_submit_alert_wrapped_form_inherits_context",
    "description": "Wrapped-form SubmitAlert inherits Severity and fans out via a 'redfish.*' envelope",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert",
    "redis_setup": [
      {
        "db": "state_db",
        "action": "delete",
        "keys": [
          "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
          "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
          "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
          "RACK_MANAGER_ALERT|Rack_level_leak"
        ]
      }
    ],
    "body": {
      "redfish_alert_data2": {
        "ShutdownAlert": {
          "FlowRateDeviation":       { "FlowRate": 58 },
          "TempDeviation":           { "InletTemperature": 17 },
          "LiquidPressureDeviation": { "LiquidPressure": 68 },
          "LeakDetected":            { "Severity": "Critical" },
          "Severity": "Major"
        }
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Rack_level_leak",
        "wait_for_field": "leak",
        "expected_fields": {
          "leak":      "Critical",
          "timestamp": { "exists": true }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
        "expected_fields": {
          "severity":  "Major",
          "timestamp": { "exists": true },
          "value":     { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
        "expected_fields": {
          "severity":  "Major",
          "timestamp": { "exists": true },
          "value":     { "exists": false }
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
        "expected_fields": {
          "severity":  "Major",
          "timestamp": { "exists": true },
          "value":     { "exists": false }
        }
      }
    ]
  }
