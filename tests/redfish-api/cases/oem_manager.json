  {
    "name": "test_submit_telemetry_persists_to_state_db",
    "description": "SubmitTelemetry flattens flags, deviations, and leak into RSCM_TELEMETRY|alarms",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitTelemetry",
    "body": {
      "Alarms": {
        "EnergyValveActive": true,
        "FlowrateSensorActive": false,
        "FlowRateDeviation":       { "FlowRate": 28,           "Severity": "Normal" },
        "InletTempDeviation":      { "InletTemperature": 25.3, "Severity": "Major" },
        "LiquidPressureDeviation": { "LiquidPressure": 2,      "Severity": "Critical" },
        "LeakDetected": {
          "LeakDetected": false,
          "LeakRopeBreak": false,
          "Severity": "Normal"
        },
        "RscmPosition": 1
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RSCM_TELEMETRY|alarms",
        "wait_for_field": "leak_detected_severity",
        "timeout": 5.0,
        "expected_fields": {
          "energy_valve_active": "true",
          "flowrate_sensor_active": "false",
          "rscm_position": "1",
          "flow_rate_deviation_flow_rate":      { "type": "float", "equals": 28 },
          "inlet_temp_deviation_temperature":   { "type": "float", "equals": 25.3 },
          "inlet_temp_deviation_severity":      "Major",
          "liquid_pressure_deviation_pressure": { "type": "float", "equals": 2 },
          "liquid_pressure_deviation_severity": "Critical",
          "leak_detected":                      "false",
          "leak_rope_break":                    "false",
          "leak_detected_severity":             "Normal"
        }
      }
    ]
  },
  {
    "name": "test_submit_alert_flat_form_persists",
    "description": "Flat-form SubmitAlert fans measurements and leaks out to canonical RACK_MANAGER_ALERT keys",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert",
    "redis_setup": [
      {
        "db": "state_db",
        "action": "delete",
        "keys": [
          "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
          "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
          "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
          "RACK_MANAGER_ALERT|leak_detected",
          "RACK_MANAGER_ALERT|leak_rope_break"
        ]
      }
    ],
    "body": {
      "redfish_alert_data": {
        "Alerts": {
          "InletTemperature": 18,
          "FlowRate": 58,
          "Severity": "Minor",
          "RscmPosition": 1
        },
        "LiquidPressureDeviation": {
          "LiquidPressure": 68,
          "Severity": "Major",
          "RscmPosition": 2
        },
        "LeakDetected":  { "Severity": "Critical", "RscmPosition": 3 },
        "LeakRopeBreak": { "Severity": "Major",    "RscmPosition": 4 }
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|leak_rope_break",
        "wait_for_field": "leak",
        "expected_fields": { "leak": "Major", "rscm_position": "4" }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
        "expected_fields": {
          "value":         { "type": "float", "equals": 18 },
          "unit":          "C",
          "severity":      "Minor",
          "rscm_position": "1"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
        "expected_fields": {
          "value":         { "type": "float", "equals": 58 },
          "unit":          "gallons_per_min",
          "severity":      "Minor",
          "rscm_position": "1"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
        "expected_fields": {
          "value":         { "type": "float", "equals": 68 },
          "unit":          "psi",
          "severity":      "Major",
          "rscm_position": "2"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|leak_detected",
        "expected_fields": { "leak": "Critical", "rscm_position": "3" }
      }
    ]
  },
  {
    "name": "test_submit_alert_wrapped_form_inherits_context",
    "description": "Wrapped-form SubmitAlert inherits Severity/RscmPosition and fans out via a 'redfish.*' key",
    "method": "POST",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert",
    "redis_setup": [
      {
        "db": "state_db",
        "action": "delete",
        "keys": [
          "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
          "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
          "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
          "RACK_MANAGER_ALERT|leak_detected",
          "RACK_MANAGER_ALERT|leak_rope_break"
        ]
      }
    ],
    "body": {
      "redfish_alert_data2": {
        "ShutdownAlert": {
          "FlowRateDeviation":       { "FlowRate": 58 },
          "TempDeviation":           { "InletTemperature": 17 },
          "LiquidPressureDeviation": { "LiquidPressure": 68 },
          "LeakDetected":            { "Severity": "Critical" },
          "Severity": "Major",
          "RscmPosition": 3
        }
      }
    },
    "expected_status": 204,
    "redis_validations": [
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|leak_detected",
        "wait_for_field": "leak",
        "expected_fields": { "leak": "Critical", "rscm_position": "3" }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_flow_rate",
        "expected_fields": {
          "value":         { "type": "float", "equals": 58 },
          "severity":      "Major",
          "rscm_position": "3"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_temperature",
        "expected_fields": {
          "value":         { "type": "float", "equals": 17 },
          "severity":      "Major",
          "rscm_position": "3"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|Inlet_liquid_pressure",
        "expected_fields": {
          "value":         { "type": "float", "equals": 68 },
          "severity":      "Major",
          "rscm_position": "3"
        }
      },
      {
        "db": "state_db",
        "key": "RACK_MANAGER_ALERT|leak_rope_break",
        "not_exists": true
      }
    ]
  }
]
