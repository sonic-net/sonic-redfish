[
  {
    "name": "test_managers_collection_returns_200",
    "description": "Managers collection is reachable",
    "method": "GET",
    "endpoint": "/redfish/v1/Managers/",
    "expected_status": 200
  },
  {
    "name": "test_bmc_manager_standard_redfish_fields",
    "description": "BMC Manager exposes standard Redfish identity fields",
    "method": "GET",
    "endpoint": "/redfish/v1/Managers/bmc",
    "expected_status": 200,
    "expected_response": {
      "@odata.id": "/redfish/v1/Managers/bmc",
      "Id": "bmc"
    },
    "validators": [
      {
        "type": "exists",
        "path": "@odata.type"
      },
      {
        "type": "exists",
        "path": "Name"
      },
      {
        "type": "exists",
        "path": "ManagerType"
      }
    ]
  },
  {
    "name": "test_bmc_manager_exposes_sonic_oem_block",
    "description": "BMC Manager carries the SONiC OEM RackManager block with both action targets",
    "method": "GET",
    "endpoint": "/redfish/v1/Managers/bmc",
    "expected_status": 200,
    "expected_response": {
      "Oem": {
        "SONiC": {
          "RackManager": {
            "@odata.type": "#SonicManager.v1_0_0.RackManager",
            "@odata.id": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager",
            "Id": "RackManager",
            "Name": "SONiC Rack Manager Interface",
            "Actions": {
              "#SONiC.SubmitAlert": {
                "target": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert"
              },
              "#SONiC.SubmitTelemetry": {
                "target": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitTelemetry"
              }
            }
          }
        }
      }
    }
  },
  {
    "name": "test_rack_manager_sub_resource_fields",
    "description": "RackManager OEM sub-resource exposes identity, description, and action fields",
    "method": "GET",
    "endpoint": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager",
    "expected_status": 200,
    "expected_response": {
      "@odata.type": "#SonicManager.v1_0_0.RackManager",
      "@odata.id": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager",
      "Id": "RackManager",
      "Name": "SONiC Rack Manager Interface",
      "Description": "OEM interface for rack manager to communicate with switch BMC",
      "Actions": {
        "#SONiC.SubmitAlert": {
          "target": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitAlert"
        },
        "#SONiC.SubmitTelemetry": {
          "target": "/redfish/v1/Managers/bmc/Oem/SONiC/RackManager/Actions/SONiC.SubmitTelemetry"
        }
      }
    }
  },
