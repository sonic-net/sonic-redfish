  {
    "name": "test_leak_schemas_served",
    "description": "All three leak-detection JSON schemas are installed in the served set and discoverable via the JsonSchemaFile collection (so describedby links resolve)",
    "method": "GET",
    "endpoint": "/redfish/v1/JsonSchemas",
    "expected_status": 200,
    "validators": [
      { "type": "contains_member", "path": "Members", "member_path": "@odata.id", "value": "/redfish/v1/JsonSchemas/LeakDetection" },
      { "type": "contains_member", "path": "Members", "member_path": "@odata.id", "value": "/redfish/v1/JsonSchemas/LeakDetector" },
      { "type": "contains_member", "path": "Members", "member_path": "@odata.id", "value": "/redfish/v1/JsonSchemas/LeakDetectorCollection" }
    ]
